{
  "name": "text-to-svg-backend",
  "version": "0.0.0",
  "description": "Convert LaTeX formulas to SVG/PNG images — backend",
  "type": "module",
  "private": true,
  "scripts": {
    "check-types": "tsc --noEmit",
    "dev": "node --watch --experimental-strip-types src/server.ts",
    "eslint": "eslint src",
    "eslint-fix": "eslint src --fix",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "start": "node --experimental-strip-types src/server.ts",
    "test": "npm run test-only && npm run check-types",
    "test-only": "vitest run --coverage",
    "test-watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.49",
    "fastify": "^5.8.5",
    "mathjax-full": "^3.2.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@zakodium/tsconfig": "^1.0.5",
    "vitest": "^4.1.5"
  },
  "volta": {
    "extends": "../package.json"
  }
}
